# Top-level deployment environment for `make doctor / tenancy-init / deploy`.
#
# Copy to .env (gitignored) and fill in your tenancy values:
#   cp env.template .env
#   # edit .env
#   make doctor
#
# For per-service deployment env vars (APM endpoints, RUM Web App OCID,
# database wallet password, etc.) see docs/CONFIGURATION.md — those go
# into deploy/vm/.env or deploy/helm/octo-apm-demo/values.yaml.

# ── OCI profile + auth ──────────────────────────────────────────────
# Profile name from ~/.oci/config (run `oci setup config` if missing).
OCI_PROFILE=DEFAULT

# Target compartment OCID — anything from your root tenancy compartment
# downward. A dedicated compartment is recommended.
OCI_COMPARTMENT_ID=

# ── OCIR (container registry) ───────────────────────────────────────
# Region key for image push, e.g. eu-frankfurt-1, us-ashburn-1, ap-tokyo-1.
OCIR_REGION=

# Tenancy object-storage namespace (same as the value `oci os ns get` returns
# for your tenancy). Usually matches the tenancy name in lowercase.
OCIR_TENANCY=

# ── Public DNS ──────────────────────────────────────────────────────
# The DNS zone where you will create A records for the storefront and
# admin hosts. The deploy will print the LB IPs after Make deploy; you
# create A records like:
#   drones.${DNS_DOMAIN}    A    <shop LB IP>
#   admin.${DNS_DOMAIN}     A    <crm LB IP>
DNS_DOMAIN=

# ── Optional knobs ──────────────────────────────────────────────────

# Override individual hostnames (defaults: drones.${DNS_DOMAIN}, admin.${DNS_DOMAIN})
# SHOP_HOST=
# ADMIN_HOST=

# Remote x86_64 builder for image builds. If unset, falls back to local Docker
# (slow on ARM Macs via QEMU). Format: user@host or ssh-config alias.
# BUILD_HOST=

# Skip building, just rollout existing images (image tag must already exist
# in OCIR). Set to 1 to skip the build step.
# SKIP_BUILD=0

# Image tag suffix. Default: latest. Useful when testing PR images.
# IMAGE_TAG=latest
