coordinator.log
debug_restart*.log

# Private live-demo captures and generated operator PDFs
site/assets/demo/private-live/
site/assets/demo/private-oci-console/
site/assets/demo/*private*.pdf
output/pdf/*private*.pdf
site/observability-v2/private-*.md
site/operations/private-*.md

# Private architecture diagram variants with resolved IPs or tenancy details.
# Published diagrams must stay sanitized and generic.
site/architecture/diagrams/*with-ips*
site/architecture/diagrams/*resolved*
site/architecture/diagrams/*private-live*
site/architecture/diagrams/*.local.drawio
site/architecture/diagrams/*.local.svg

