# Unified VM deployment env template.
# Copy to deploy/vm/.env and fill in. Never commit the real .env.

# ── OCIR image source ──────────────────────────────────────────────────
OCIR_REGION=eu-frankfurt-1
OCIR_TENANCY=
SHOP_IMAGE_TAG=latest
CRM_IMAGE_TAG=latest
JAVA_APM_IMAGE_TAG=latest
WORKFLOW_GATEWAY_IMAGE_TAG=latest

# ── Public DNS (resolves to this VM's IP) ──────────────────────────────
# shop → shop.${DNS_DOMAIN}
# crm  → crm.${DNS_DOMAIN}
DNS_DOMAIN=
SHOP_PUBLIC_URL=
CORS_ALLOWED_ORIGINS=

# ── Shared cross-service auth (generate once, reuse on both sides) ─────
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_KEY=
AUTH_TOKEN_SECRET=
APP_SECRET_KEY=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Oracle Autonomous Database ─────────────────────────────────────────
# Download the wallet.zip from OCI Console → ATP → DB Connection,
# then: unzip wallet.zip -d deploy/vm/wallet
ORACLE_DSN=                    # e.g. myatp_low from tnsnames.ora
ORACLE_USER=ADMIN
ORACLE_PASSWORD=
ORACLE_WALLET_PASSWORD=
ATP_OCID=
DATABASE_OBSERVABILITY_ENABLED=true

# ── OCI Observability (optional) ───────────────────────────────────────
ENVIRONMENT=production
OCI_AUTH_MODE=instance_principal
OCI_REGION=
OCI_COMPARTMENT_ID=
OCI_MONITORING_NAMESPACE=octo_apm_demo
SERVICE_NAMESPACE=octo
DEMO_STACK_NAME=octo-vm
APP_TOPOLOGY_PROFILE=single-vm
SHOP_OTEL_SERVICE_NAME=octo-drone-shop
CRM_OTEL_SERVICE_NAME=enterprise-crm-portal
SHOP_SERVICE_INSTANCE_ID=octo-drone-shop-vm
CRM_SERVICE_INSTANCE_ID=enterprise-crm-portal-vm
JAVA_APM_SERVICE_INSTANCE_ID=octo-java-app-server-vm
WORKFLOW_SERVICE_INSTANCE_ID=octo-workflow-gateway-vm
OTEL_TRACES_SAMPLER=always_on
OTEL_PYTHON_LOG_CORRELATION=true
OTLP_LOG_EXPORT_ENABLED=false
OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PUBLIC_DATAKEY=
OCI_APM_RUM_ENDPOINT=
OCI_APM_WEB_APPLICATION=octo-drone-shop-web
OCI_APM_RUM_PUBLIC_DATAKEY=
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
OCI_LOG_CHAOS_AUDIT_ID=
OCI_LOG_SECURITY_ID=

# ── Payment, workflow, Select AI, and LLMetry ─────────────────────────
JAVA_APM_ENABLED=true
JAVA_APM_SERVICE_URL=http://java-apm:8080
JAVA_APM_SERVICE_NAME=octo-java-app-server
JAVA_APM_TIMEOUT_SECONDS=3.0
PAYMENT_PROVIDER=simulated
PAYMENT_GATEWAY_SIMULATION_ENABLED=true
PAYMENT_SIMULATION_MODE=approve
PAYMENT_SIMULATION_CURRENCY=usd
WORKFLOW_API_BASE_URL=http://workflow-gateway:8090
WORKFLOW_PUBLIC_API_BASE_URL=/api/workflow-gateway
WORKFLOW_SERVICE_NAME=octo-workflow-gateway
WORKFLOW_POLL_SECONDS=90
WORKFLOW_FAULTY_QUERY_ENABLED=false
SELECTAI_PROFILE_NAME=
SELECTAI_TIMEOUT_SECONDS=30
OCI_GENAI_ENDPOINT=
OCI_GENAI_MODEL_ID=
LLMETRY_ENABLED=true
LLMETRY_STORE_ENABLED=true
LLMETRY_CAPTURE_CONTENT=false
LANGFUSE_ENABLED=false
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_OTEL_EXPORT_ENABLED=true
LANGFUSE_TIMEOUT_SECONDS=2.0
LANGFUSE_INGESTION_VERSION=4

# ── Synthetic demo users/orders ───────────────────────────────────────
SYNTHETIC_USERS_ENABLED=true
SYNTHETIC_USER_EMAIL_DOMAIN=apex.example.test
SYNTHETIC_USER_COUNT=12
SYNTHETIC_USER_ORDER_COUNT=6
SYNTHETIC_USER_DELETE_AFTER_DAYS=7
SYNTHETIC_USER_JOB_TIMEOUT_SECONDS=30

# ── IDCS SSO (optional) ────────────────────────────────────────────────
IDCS_DOMAIN_URL=
IDCS_CLIENT_ID=
IDCS_CLIENT_SECRET=
