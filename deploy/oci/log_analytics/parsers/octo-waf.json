{
  "name": "octo-waf",
  "description": "OCI WAF event log \u2014 request, rule, client, and correlation.",
  "type": "JSON",
  "isEnabled": true,
  "fieldMaps": [
    {
      "sourcePath": "$.time",
      "logFieldName": "Time"
    },
    {
      "sourcePath": "$.data.httpHost",
      "logFieldName": "Edge Request Host"
    },
    {
      "sourcePath": "$.data.requestUrl",
      "logFieldName": "URL Path"
    },
    {
      "sourcePath": "$.data.httpMethod",
      "logFieldName": "Method"
    },
    {
      "sourcePath": "$.data.responseCode",
      "logFieldName": "HTTP Status Code"
    },
    {
      "sourcePath": "$.data.clientAddress",
      "logFieldName": "Host IP Address (Client)"
    },
    {
      "sourcePath": "$.data.countryCode",
      "logFieldName": "Client Host Country Code"
    },
    {
      "sourcePath": "$.data.action",
      "logFieldName": "Security Action"
    },
    {
      "sourcePath": "$.data.ruleName",
      "logFieldName": "Security Rule"
    },
    {
      "sourcePath": "$.data.ruleType",
      "logFieldName": "Security Event Classification"
    },
    {
      "sourcePath": "$.data.requestHeaders.x-request-id",
      "logFieldName": "Request ID"
    },
    {
      "sourcePath": "$.data.requestHeaders.traceparent",
      "logFieldName": "Trace ID"
    }
  ]
}
