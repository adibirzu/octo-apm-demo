{
  "name": "octo-chaos-audit",
  "description": "Chaos admin audit trail emitted by CRM.",
  "type": "JSON",
  "isEnabled": true,
  "fieldMaps": [
    {
      "sourcePath": "$.ts",
      "logFieldName": "Time"
    },
    {
      "sourcePath": "$.event",
      "logFieldName": "Event"
    },
    {
      "sourcePath": "$.scenario_id",
      "logFieldName": "Event Types"
    },
    {
      "sourcePath": "$.target",
      "logFieldName": "Target"
    },
    {
      "sourcePath": "$.ttl_seconds",
      "logFieldName": "Duration"
    },
    {
      "sourcePath": "$.applied_by",
      "logFieldName": "User ID"
    },
    {
      "sourcePath": "$.request_id",
      "logFieldName": "Request ID"
    }
  ]
}
