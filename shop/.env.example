# OCTO Drone Shop shared environment template
# Copy to .env.local for local runs. Do not commit real secrets.

# DNS domain — all public URLs and CORS origins are derived from this.
# Set once per tenancy; leave empty for local dev (localhost:8080).
DNS_DOMAIN=

# Application
APP_NAME=octo-drone-shop
OTEL_SERVICE_NAME=octo-drone-shop
OBSERVABILITY_APP_NAME=
OBSERVABILITY_SERVICE_NAME=
APP_RUNTIME=oke
ENVIRONMENT=production
PORT=8080
OCI_AUTH_MODE=instance_principal
AUTH_TOKEN_SECRET=
AUTH_TOKEN_SECRET_FILE=
# Shared secret for CRM → Drone Shop server-to-server simulation proxy.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SERVICE_KEY=
INTERNAL_SERVICE_KEY_FILE=
SEED_USER_EMAIL_DOMAIN=example.invalid
SEED_PAGEVIEW_IP_PREFIX=198.18.0.

# Oracle ATP
ORACLE_DSN=
ORACLE_USER=ADMIN
ORACLE_PASSWORD=
ORACLE_PASSWORD_FILE=
ORACLE_WALLET_DIR=/opt/oracle/wallet
ORACLE_WALLET_PASSWORD=
ORACLE_WALLET_PASSWORD_FILE=
ORACLE_WALLET_PATH=./wallet

# Integrations
# Canonical name for the CRM base URL. ENTERPRISE_CRM_URL is accepted as a
# deprecated alias and will be removed in a future release.
SERVICE_CRM_URL=
ENTERPRISE_CRM_URL=
# Public browser URL for CRM links/status payloads. Keep ENTERPRISE_CRM_URL
# private for in-cluster service-to-service traffic.
CRM_PUBLIC_URL=
OCI_COMPARTMENT_ID=
OCI_GENAI_ENDPOINT=
OCI_GENAI_MODEL_ID=
WORKFLOW_API_BASE_URL=
# Optional public browser URL for the workflow gateway if the backend URL is
# private/internal (for example, cluster-local or API Gateway split-horizon).
WORKFLOW_PUBLIC_API_BASE_URL=
WORKFLOW_SERVICE_NAME=octo-workflow-gateway
WORKFLOW_POLL_SECONDS=90
# Derived from DNS_DOMAIN when set (e.g. https://shop.<domain>,https://crm.<domain>)
WORKFLOW_ALLOWED_ORIGINS=
WORKFLOW_FAULTY_QUERY_ENABLED=false
SELECTAI_PROFILE_NAME=

# OCI APM / RUM
OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PRIVATE_DATAKEY_FILE=
OCI_APM_PUBLIC_DATAKEY=
OCI_APM_RUM_ENDPOINT=
OCI_APM_WEB_APPLICATION=octo-drone-shop-web

# OCI Console Drilldown URLs (360 Monitoring dashboard links)
APM_CONSOLE_URL=
OPSI_CONSOLE_URL=
DB_MANAGEMENT_CONSOLE_URL=
LOG_ANALYTICS_CONSOLE_URL=

# IDCS / OCI IAM Identity Domain (OIDC SSO)
# In a new tenancy: register a "Confidential Application" in the IAM domain,
# enable Authorization Code grant + scopes openid/profile/email, and copy the
# values below from the application's "OAuth configuration" tab.
IDCS_DOMAIN_URL=
IDCS_CLIENT_ID=
IDCS_CLIENT_SECRET=
IDCS_CLIENT_SECRET_FILE=
# Auto-derived from DNS_DOMAIN when set. Override only if needed.
IDCS_REDIRECT_URI=
IDCS_SCOPE=openid profile email
IDCS_POST_LOGOUT_REDIRECT=
# Set to "false" only in air-gapped dev where the JWKS endpoint is unreachable
IDCS_VERIFY_JWT=true

# Tenancy-portable load balancer subnet (used by deploy/k8s/deployment.yaml)
OCI_LB_SUBNET_OCID=

# OCI Monitoring (custom metrics — published to OCI Monitoring service)
# Requires OCI_COMPARTMENT_ID above. Metrics appear in OCI Console → Monitoring.
OCI_MONITORING_NAMESPACE=octo_drone_shop
OCI_MONITORING_INTERVAL_SECONDS=60

# Logging
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_TOKEN_FILE=
OTLP_LOG_EXPORT_ENABLED=false
