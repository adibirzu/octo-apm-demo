{
  "name": "octo-drone-shop-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "E2E test suite for OCTO Drone Shop and the companion CRM",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:health": "playwright test tests/e2e/health.spec.ts",
    "test:e2e:shopping": "playwright test tests/e2e/shopping-flow.spec.ts",
    "test:e2e:payments": "playwright test tests/e2e/payment-gateway-trace.spec.ts",
    "test:e2e:synthetic-apm": "playwright test --config=tools/apm/playwright.config.ts",
    "test:e2e:cross-service": "playwright test tests/e2e/cross-service.spec.ts",
    "test:e2e:melts": "playwright test tests/e2e/melts.spec.ts",
    "test:e2e:auth": "playwright test tests/e2e/auth-sso.spec.ts",
    "test:e2e:admin": "playwright test tests/e2e/admin-data-management.spec.ts",
    "test:e2e:demo-script": "playwright test tests/e2e/demo-script.spec.ts",
    "test:e2e:simulation": "playwright test tests/e2e/simulation.spec.ts",
    "test:e2e:availability": "playwright test tests/e2e/availability.spec.ts",
    "test:e2e:k6": "playwright test tests/e2e/k6-integration.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3"
  }
}
